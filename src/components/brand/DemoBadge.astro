---
// Píldora que marca claramente las vistas con datos de prueba.
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
interface Props { class?: string; }
const { class: cls = "" } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<span class:list={["demo-badge", cls]}>
  <span class="demo-badge__dot" aria-hidden="true"></span>
  {t("demo.badge")}
</span>
<style>
  .demo-badge {
    display: inline-flex; align-items: center; gap: 7px;
    font-family: var(--font-mono); font-weight: 700; font-size: 11px;
    letter-spacing: var(--ls-overline); text-transform: uppercase;
    color: var(--ink-900); background: var(--marigold-400);
    padding: 5px 12px; border-radius: var(--radius-pill);
  }
  .demo-badge__dot { width: 7px; height: 7px; border-radius: 50%; background: var(--ink-900); }
</style>
