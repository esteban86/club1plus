---
interface Props { symbol?: "plus" | "equals" | "rise" | "ring" | "spark"; size?: number; color?: string; title?: string; class?: string; }
const { symbol = "plus", size = 48, color = "currentColor", title, class: cls = "" } = Astro.props;
// El color se inyecta como propiedad CSS `color` (resuelve var() de forma fiable);
// las formas pintan con currentColor. Si es el default, no forzamos nada y se hereda.
const style = color !== "currentColor" ? `color:${color}` : undefined;
---
<svg width={size} height={size} viewBox="0 0 100 100" role="img" aria-label={title ?? symbol} class={cls} style={style}>
  {title && <title>{title}</title>}
  {symbol === "plus" && (<g fill="currentColor"><rect x="43.5" y="16" width="13" height="68" rx="5" /><rect x="16" y="43.5" width="68" height="13" rx="5" /></g>)}
  {symbol === "equals" && (<g fill="currentColor"><rect x="18" y="35" width="64" height="13" rx="6" /><rect x="18" y="57" width="64" height="13" rx="6" /></g>)}
  {symbol === "rise" && (<g fill="currentColor"><rect x="18" y="56" width="16" height="28" rx="5" /><rect x="42" y="40" width="16" height="44" rx="5" /><rect x="66" y="22" width="16" height="62" rx="5" /></g>)}
  {symbol === "ring" && (<circle cx="50" cy="50" r="30" fill="currentColor" />)}
  {symbol === "spark" && (<path d="M50 8 C53.5 35 65 46.5 92 50 C65 53.5 53.5 65 50 92 C46.5 65 35 53.5 8 50 C35 46.5 46.5 35 50 8 Z" fill="currentColor" />)}
</svg>
