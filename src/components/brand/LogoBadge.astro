---
interface Props { size?: number; variant?: "green" | "dark"; class?: string; }
const { size = 72, variant = "green", class: cls = "" } = Astro.props;
const green = variant === "green";
---
<svg
  width={size}
  height={size}
  viewBox="0 0 200 200"
  role="img"
  aria-label="El Club del 1+"
  class:list={["logo", `logo--${variant}`, cls]}
>
  <circle class="logo__bg" cx="100" cy="100" r={green ? 100 : 96} />
  <text class="logo__fg" x="66" y="131" text-anchor="middle" font-weight="900" font-size="104" letter-spacing="-4">1</text>
  <g class="logo__fg">
    <rect x="108" y="66" width="19" height="58" rx="4" />
    <rect x="88" y="86" width="59" height="19" rx="4" />
  </g>
  <text class="logo__fg" x="100" y="173" text-anchor="middle" font-weight="800" font-size="34" letter-spacing="0.5">club</text>
</svg>

<style>
  /* Colores y fuente vía CSS (no atributos de presentación): var() resuelve
     de forma fiable en todos los navegadores, incluido Safari. */
  .logo__fg { font-family: var(--font-display); }
  .logo--green .logo__bg { fill: var(--green-400); }
  .logo--green .logo__fg { fill: var(--ink-900); }
  .logo--dark .logo__bg { fill: var(--ink-800); stroke: var(--green-400); stroke-width: 8; }
  .logo--dark .logo__fg { fill: var(--green-400); }
</style>
