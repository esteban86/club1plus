---
import Overline from "../brand/Overline.astro";
import { getLangFromUrl } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const d = lang === "es"
  ? {
      over: "Metas 2026",
      title: "A dónde vamos este año.",
      goals: [
        { figure: "50", label: "mujeres atendidas en 2026" },
        { figure: "+20%", label: "aumento en sus ingresos" },
        { figure: "+60%", label: "reportan mejoras en salud mental y bienestar" },
        { figure: "70%", label: "donantes fidelizados" },
      ],
    }
  : {
      over: "2026 goals",
      title: "Where we're headed this year.",
      goals: [
        { figure: "50", label: "women supported in 2026" },
        { figure: "+20%", label: "increase in their income" },
        { figure: "+60%", label: "report better mental health and wellbeing" },
        { figure: "70%", label: "donors retained" },
      ],
    };
---
<section class="ground-paper-100 section">
  <div class="container">
    <Overline tone="muted">{d.over}</Overline>
    <h2 class="display goals__title">{d.title}</h2>
    <div class="goals__grid">
      {d.goals.map((g) => (
        <div class="goal reveal">
          <span class="goal__figure">{g.figure}</span>
          <span class="goal__label">{g.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .goals__title { font-size: clamp(26px, 4vw, 40px); color: var(--text-strong); margin-top: 14px; padding-bottom: 0.1em; }
  .goals__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 40px; }
  .goal { background: var(--paper-0); border: 1px solid var(--paper-200); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); padding: 28px 24px; display: flex; flex-direction: column; gap: 10px; }
  .goal__figure { font-family: var(--font-display); font-weight: 900; font-size: clamp(40px, 5vw, 56px); letter-spacing: -0.03em; color: var(--green-600); line-height: 1; }
  .goal__label { font-family: var(--font-body); font-weight: 500; font-size: 14.5px; line-height: 1.45; color: var(--text-body); }
  @media (max-width: 820px) { .goals__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .goals__grid { grid-template-columns: 1fr; } }
</style>
