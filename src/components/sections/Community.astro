---
import Overline from "../brand/Overline.astro";
import Button from "../brand/Button.astro";
import { getLangFromUrl, getRoute } from "../../i18n/utils";
import { PUBLIC_STATS } from "../../lib/demo/data";
import { renderGraphSVG } from "../../lib/demo/portal-ui";

const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const isEn = lang === "en";
const numLocale = isEn ? "en-US" : "es-CO";
const graph = renderGraphSVG("daniela", { anonymizeAll: true });

const c = {
  over: isEn ? "The community, live" : "La comunidad, en vivo",
  title: isEn ? "One + multiplies." : "Un + se multiplica.",
  intro: isEn
    ? "Every member can bring others in. A friend invites a friend, who invites another — and the impact grows several levels deep. This is what the Club's network looks like."
    : "Cada socio puede traer a otros. Un amigo invita a un amigo, que invita a otro — y el impacto crece varios niveles. Así se ve la red del Club.",
  members: isEn ? "members" : "socios",
  mothers: isEn ? "mothers with income" : "madres con renta",
  transferred: isEn ? "transferred to mothers" : "transferido a las madres",
  graphTitle: isEn ? "A referral network, anonymized" : "Una red de referidos, anonimizada",
  graphNote: isEn
    ? "Public view: names are never shown. Green = active member, dashed = invited (pending)."
    : "Vista pública: nunca se muestran nombres. Verde = socio activo, punteado = invitado (pendiente).",
  legMember: isEn ? "Active member" : "Socio activo",
  legPending: isEn ? "Invited (pending)" : "Invitado (pendiente)",
  ambKick: isEn ? "Be an ambassador" : "Sé embajador",
  ambTitle: isEn ? "Your + can become many." : "Tu + puede volverse muchos.",
  ambBody: isEn
    ? "Share your link. Every person who joins through you appears in your network — and brings more mothers closer to their income."
    : "Comparte tu enlace. Cada persona que entra por ti aparece en tu red — y acerca a más madres a su renta.",
  sample: isEn ? "Your link will look like this:" : "Tu enlace se verá así:",
  copy: isEn ? "Copy" : "Copiar",
  copied: isEn ? "Copied!" : "¡Copiado!",
  getLink: isEn ? "Get my link" : "Genera tu enlace",
  join: isEn ? "Become a member" : "Sé socio",
  note: isEn ? "Demo figures · sample data" : "Cifras de la demo · datos de prueba",
};
const sampleLink = "clubdel1.org/r/TUNOMBRE";
---
<section class="ground-ink section plus-texture-green">
  <div class="container">
    <Overline tone="green">{c.over}</Overline>
    <h1 class="display comm__title">{c.title}</h1>
    <p class="comm__intro">{c.intro}</p>
    <div class="comm__stats">
      <div class="comm__stat"><div class="comm__n" data-count data-to={PUBLIC_STATS.members} data-locale={numLocale}>0</div><div class="comm__l">{c.members}</div></div>
      <div class="comm__stat"><div class="comm__n" data-count data-to={PUBLIC_STATS.mothersActive} data-locale={numLocale}>0</div><div class="comm__l">{c.mothers}</div></div>
      <div class="comm__stat"><div class="comm__n" data-count data-to={PUBLIC_STATS.transferredCop} data-locale={numLocale} data-prefix="$" data-compact="cop">$0</div><div class="comm__l">{c.transferred}</div></div>
    </div>
    <p class="comm__note">{c.note}</p>
  </div>
</section>

<section class="ground-paper-100 section">
  <div class="container">
    <Overline tone="green">{c.graphTitle}</Overline>
    <div class="comm__graphcard">
      <div class="comm__graph-scroll" set:html={graph} />
      <div class="comm__legend">
        <span><span class="comm__swatch" style="background:#2BE06F"></span>{c.legMember}</span>
        <span><span class="comm__swatch" style="background:#fff;border:2px solid #19C95E"></span>{c.legPending}</span>
      </div>
      <p class="comm__gnote">{c.graphNote}</p>
    </div>
  </div>
</section>

<section class="ground-green section plus-texture-ink">
  <div class="container">
    <Overline tone="dark">{c.ambKick}</Overline>
    <h2 class="display comm__amb-title">{c.ambTitle}</h2>
    <p class="comm__amb-body">{c.ambBody}</p>
    <p class="comm__sample-l">{c.sample}</p>
    <div class="comm__reflink">
      <input id="comm-link" readonly value={sampleLink} data-copied={c.copied} />
      <button class="btn btn--dark btn--md" id="comm-copy">{c.copy}</button>
    </div>
    <div class="comm__amb-actions">
      <Button href={base + getRoute("ingresar", lang)} variant="dark" size="lg">{c.getLink} →</Button>
      <Button href={base + getRoute("donar", lang)} variant="outline" size="lg">{c.join}</Button>
    </div>
  </div>
</section>

<script>
  import { initCountUp } from "../../lib/demo/countup";
  function wireCommunity() {
    initCountUp();
    const btn = document.getElementById("comm-copy");
    const input = document.getElementById("comm-link") as HTMLInputElement | null;
    if (btn && input) {
      const copyLabel = btn.textContent || "Copiar";
      btn.addEventListener("click", async () => {
        try { await navigator.clipboard.writeText(input.value); } catch { input.select(); }
        const done = input.dataset.copied || "¡Copiado!";
        btn.textContent = done;
        setTimeout(() => (btn.textContent = copyLabel), 1600);
      });
    }
  }
  document.addEventListener("astro:page-load", wireCommunity);
</script>

<style>
  .comm__title { font-size: clamp(32px, 5.5vw, 56px); color: var(--paper-50); margin-top: 14px; max-width: 16ch; line-height: 1.05; }
  .comm__intro { font-family: var(--font-body); font-weight: 500; font-size: clamp(16px, 2vw, 19px); color: var(--text-on-dark); max-width: 56ch; margin-top: 16px; }
  .comm__stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px; }
  @media (max-width: 720px) { .comm__stats { grid-template-columns: 1fr; gap: 24px; } }
  .comm__stat { border-left: 3px solid var(--green-400); padding-left: 18px; }
  .comm__n { font-family: var(--font-display); font-weight: 900; letter-spacing: -0.03em; font-size: clamp(38px, 6vw, 60px); color: var(--green-400); line-height: 1; }
  .comm__l { font-family: var(--font-body); font-weight: 600; font-size: 15px; color: var(--text-on-dark); margin-top: 8px; }
  .comm__note { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-400); margin-top: 22px; }

  .comm__graphcard { background: var(--paper-0); border: 1px solid var(--paper-200); border-radius: var(--radius-md); padding: 24px; margin-top: 24px; box-shadow: var(--shadow-sm); }
  .comm__graph-scroll { overflow-x: auto; }
  .comm__graph-scroll :global(svg) { display: block; margin-inline: auto; }
  .comm__legend { display: flex; gap: 20px; flex-wrap: wrap; margin-top: 12px; font-size: 14px; color: var(--text-muted); }
  .comm__legend span { display: inline-flex; align-items: center; gap: 8px; }
  .comm__swatch { width: 13px; height: 13px; border-radius: 50%; }
  .comm__gnote { font-size: 13px; color: var(--text-muted); margin-top: 10px; }

  .comm__amb-title { font-size: clamp(28px, 4.5vw, 46px); color: var(--ink-900); margin-top: 14px; max-width: 16ch; padding-bottom: 0.08em; }
  .comm__amb-body { font-family: var(--font-body); font-weight: 500; font-size: clamp(16px, 2vw, 19px); color: var(--ink-900); opacity: 0.88; max-width: 52ch; margin-top: 12px; }
  .comm__sample-l { font-family: var(--font-mono); font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-900); opacity: 0.7; margin-top: 24px; }
  .comm__reflink { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-top: 8px; max-width: 480px; }
  .comm__reflink input { flex: 1 1 240px; min-width: 0; font-family: var(--font-mono); font-size: 14px; padding: 13px 16px; border: 2px solid var(--ink-900); border-radius: var(--radius-md); background: rgba(255,255,255,0.6); color: var(--ink-900); }
  .comm__amb-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 22px; }
</style>
