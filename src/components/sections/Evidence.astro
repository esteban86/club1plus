---
import Overline from "../brand/Overline.astro";
import Highlight from "../brand/Highlight.astro";
import YouTubeEmbed from "../brand/YouTubeEmbed.astro";
import { getCollection } from "astro:content";
import { getLangFromUrl } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const all = (await getCollection("evidence", (e) => e.data.lang === lang)).sort((a, b) => a.data.order - b.data.order);
const cases = all.filter((e) => e.data.kind === "case");
const resources = all.filter((e) => e.data.kind === "resource");

const VIDEO_ID = "_gTgloPR0Aw";
const VIDEO_TITLE = "What's the best way to lift people out of poverty? · TED-Ed";

const copy = lang === "es"
  ? { over: "Evidencia", before: "Dar dinero, sin condiciones, ", hl: "funciona.",
      lead: "No es una teoría: la renta básica ya se probó en el mundo, con resultados medidos. Esta es la evidencia que nos inspira — y la lógica detrás de nuestro piloto.",
      videoH: "Míralo en 5 minutos", casesH: "Casos probados en el mundo", resH: "Lecturas y recursos", src: "Ver fuente" }
  : { over: "Evidence", before: "Giving money, no strings attached, ", hl: "works.",
      lead: "It's not a theory: basic income has been tested around the world, with measured results. This is the evidence that inspires us — and the logic behind our pilot.",
      videoH: "Watch it in 5 minutes", casesH: "Proven cases worldwide", resH: "Reading & resources", src: "View source" };
---
<section class="ground-ink plus-texture-green section">
  <div class="container">
    <Overline tone="green">{copy.over}</Overline>
    <h1 class="display ev__title">{copy.before}<Highlight variant="green">{copy.hl}</Highlight></h1>
    <p class="ev__lead">{copy.lead}</p>

    <h2 class="ev__sub ev__sub--dark">{copy.videoH}</h2>
    <div class="ev__video">
      <YouTubeEmbed id={VIDEO_ID} title={VIDEO_TITLE} poster={base + "/evidence/video-poster.jpg"} />
      <p class="ev__video-cap">{VIDEO_TITLE}</p>
    </div>

    <h2 class="ev__sub ev__sub--dark">{copy.casesH}</h2>
    <div class="ev__grid">
      {cases.map((c) => (
        <a class="ecase reveal" href={c.data.url} target="_blank" rel="noopener noreferrer">
          {c.data.image && <img class="ecase__img" src={base + c.data.image} alt={c.data.title} loading="lazy" width="800" height="450" />}
          <div class="ecase__body">
            <span class="ecase__meta">{c.data.meta}</span>
            <h3 class="ecase__title">{c.data.title}</h3>
            {c.data.result && <p class="ecase__result">{c.data.result}</p>}
            <p class="ecase__summary">{c.data.summary}</p>
            <span class="ecase__src">{copy.src}{c.data.source ? ` · ${c.data.source}` : ""} <span class="ecase__arrow">→</span></span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="ground-paper section">
  <div class="container">
    <h2 class="ev__sub ev__sub--light">{copy.resH}</h2>
    <div class="ev__grid ev__grid--res">
      {resources.map((r) => (
        <a class="eres reveal" href={r.data.url} target="_blank" rel="noopener noreferrer">
          {r.data.image && <img class="eres__cover" src={base + r.data.image} alt={r.data.title} loading="lazy" />}
          <div class="eres__body">
            <span class="eres__meta">{r.data.meta}</span>
            <h3 class="eres__title">{r.data.title}</h3>
            <p class="eres__summary">{r.data.summary}</p>
            <span class="eres__arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .ev__title { font-size: clamp(32px, 5.5vw, 56px); color: var(--paper-50); max-width: 20ch; margin-top: 14px; line-height: 1.05; padding-bottom: 0.1em; }
  .ev__lead { font-family: var(--font-body); font-weight: 500; font-size: clamp(16px, 2.2vw, 19px); line-height: 1.55; color: var(--text-on-dark); opacity: 0.9; max-width: 56ch; margin-top: 18px; }
  .ev__sub { font-family: var(--font-display); font-weight: 800; font-size: clamp(20px, 3vw, 26px); margin: 0 0 24px; }
  .ev__sub--dark { color: var(--paper-50); margin-top: 56px; }
  .ev__sub--light { color: var(--text-strong); }

  .ev__video { max-width: 760px; }
  .ev__video-cap { font-family: var(--font-mono); font-weight: 700; font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--text-on-dark-muted); margin-top: 14px; }

  .ev__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .ev__grid--res { grid-template-columns: repeat(3, 1fr); }

  .ecase { display: flex; flex-direction: column; background: var(--surface-dark-raised); border: 1px solid var(--border-dark); border-radius: var(--radius-md); overflow: hidden; text-decoration: none; transition: transform var(--dur-base) var(--ease-out), border-color var(--dur-base) var(--ease-out); }
  .ecase:hover { transform: translateY(-4px); border-color: var(--green-400); }
  .ecase__img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; display: block; }
  .ecase__body { display: flex; flex-direction: column; flex: 1; padding: 24px 26px 26px; }
  .ecase__meta { font-family: var(--font-mono); font-weight: 700; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--green-400); }
  .ecase__title { font-family: var(--font-display); font-weight: 800; font-size: 21px; color: var(--paper-50); margin: 12px 0 0; line-height: 1.15; }
  .ecase__result { display: inline-block; align-self: flex-start; background: var(--green-400); color: var(--ink-900); font-family: var(--font-display); font-weight: 800; font-size: 15px; padding: 5px 12px; border-radius: var(--radius-pill); margin: 16px 0 0; }
  .ecase__summary { font-family: var(--font-body); font-weight: 500; font-size: 14.5px; line-height: 1.5; color: var(--text-on-dark-muted); margin: 16px 0 0; flex: 1; }
  .ecase__src { font-family: var(--font-mono); font-weight: 700; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--green-400); margin-top: 20px; display: inline-flex; align-items: center; gap: 6px; }
  .ecase__arrow { transition: transform var(--dur-base) var(--ease-out); }
  .ecase:hover .ecase__arrow { transform: translateX(4px); }

  .eres { display: flex; gap: 18px; background: var(--paper-0); border: 1px solid var(--paper-200); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); padding: 22px; text-decoration: none; transition: transform var(--dur-base) var(--ease-out), box-shadow var(--dur-base) var(--ease-out); }
  .eres:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .eres__cover { width: 96px; flex: none; aspect-ratio: 2 / 3; object-fit: cover; border-radius: var(--radius-sm); box-shadow: var(--shadow-sm); align-self: flex-start; }
  .eres__body { display: flex; flex-direction: column; }
  .eres__meta { font-family: var(--font-mono); font-weight: 700; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); }
  .eres__title { font-family: var(--font-display); font-weight: 800; font-size: 19px; color: var(--ink-900); margin: 8px 0 0; }
  .eres__summary { font-family: var(--font-body); font-weight: 500; font-size: 14px; line-height: 1.5; color: var(--text-body); margin: 10px 0 0; }
  .eres__arrow { font-family: var(--font-display); font-weight: 800; font-size: 20px; color: var(--green-700); margin-top: 14px; transition: transform var(--dur-base) var(--ease-out); }
  .eres:hover .eres__arrow { transform: translateX(4px); }

  @media (max-width: 820px) { .ev__grid, .ev__grid--res { grid-template-columns: 1fr; } }
</style>
