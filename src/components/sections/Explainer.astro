</div>

<script>
  function setupExplainer() {
    // progreso de scroll
    const prog = document.querySelector("[data-prog]") as HTMLElement | null;
    if (prog) {
      const onScroll = () => {
        const h = document.documentElement;
        const max = h.scrollHeight - h.clientHeight;
        prog.style.width = (max > 0 ? (h.scrollTop / max) * 100 : 0) + "%";
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    }
    // count up
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        const el = e.target as HTMLElement;
        io.unobserve(el);
        const to = parseFloat(el.dataset.to || "0");
        const prefix = el.dataset.prefix || "", suffix = el.dataset.suffix || "";
        const locale = el.dataset.locale || "es-CO";
        let start = 0;
        const tick = (t: number) => {
          if (!start) start = t;
          const p = Math.min(1, (t - start) / 1400);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = prefix + Math.round(to * eased).toLocaleString(locale) + suffix;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }
    }, { threshold: 0.5 });
    document.querySelectorAll("[data-countup]").forEach((el) => io.observe(el));

    // trap loop toggle
    document.querySelectorAll("[data-loop]").forEach((node) => {
      const loop = node as HTMLElement;
      const btn = loop.querySelector("[data-loop-btn]");
      if (!btn || loop.dataset.bound) return;
      loop.dataset.bound = "1";
      const origBtn = btn.innerHTML;
      btn.addEventListener("click", () => {
        const broken = loop.classList.toggle("is-broken");
        loop.querySelectorAll("[data-node]").forEach((nd) => {
          const n = nd as HTMLElement;
          (n.querySelector(".node__t") as HTMLElement).textContent = broken ? n.dataset.et! : n.dataset.bt!;
          (n.querySelector(".node__s") as HTMLElement).textContent = broken ? n.dataset.es! : n.dataset.bs!;
        });
        const center = loop.querySelector(".loop__center");
        if (center) center.textContent = broken ? loop.dataset.centerOn! : loop.dataset.centerOff!;
        const sub = loop.querySelector(".loop__sub");
        if (sub) sub.textContent = broken ? loop.dataset.subOn! : loop.dataset.subOff!;
        btn.innerHTML = broken ? loop.dataset.btnOn! : origBtn;
      });
    });
  }
  document.addEventListener("astro:page-load", setupExplainer);
</script>

