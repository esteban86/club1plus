---
import Overline from "../brand/Overline.astro";
import Highlight from "../brand/Highlight.astro";
import CircledWord from "../brand/CircledWord.astro";
import BrandSymbol from "../brand/BrandSymbol.astro";
import StatBar from "../brand/StatBar.astro";
import LogoBadge from "../brand/LogoBadge.astro";
import Button from "../brand/Button.astro";
import { getLangFromUrl, getRoute } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const donar = base + getRoute("donar", lang);
const benef = base + getRoute("beneficiarias", lang);

const expenses = ["Arriendo", "Comida", "Servicios", "Transporte", "Deuda de fiado"];
const evidence: { sym: "rise" | "ring" | "plus" | "spark"; t: string; d: string }[] = [
  { sym: "rise", t: "Lo invierten", d: "Mercancía, un puesto, una máquina. El ingreso propio sube y se sostiene." },
  { sym: "ring", t: "No dejan de trabajar", d: "El mito de la “pereza” no se sostiene: trabajan igual o más, con un plan." },
  { sym: "plus", t: "Los hijos ganan", d: "Mejor alimentación y más permanencia escolar — la trampa no pasa a la siguiente generación." },
  { sym: "spark", t: "Dignidad y decisión", d: "Cada familia sabe mejor que nadie qué necesita primero. El efectivo lo respeta." },
];
const steps = [
  { n: "01", t: "Estabilidad", d: "Sé que algo llega cada mes." },
  { n: "02", t: "Puedo planear", d: "Y arriesgarme a invertir." },
  { n: "03", t: "Ingreso propio", d: "Un negocio que crece." },
  { n: "04", t: "Salida real", d: "Que se queda y se hereda." },
];
const meters = [
  { lab: "Un ingreso digno", h: 200, c: "var(--green-400)", below: false },
  { lab: "Bajo la línea", h: 96, c: "var(--coral-400)", below: true },
  { lab: "Pobreza extrema", h: 52, c: "var(--coral-500)", below: true },
];
// nodos del bucle: textos para los dos estados
const nodes = [
  { cls: "n0", bt: "Ingreso bajo", bs: "No alcanza el mes", et: "Estabilidad", es: "Algo llega cada mes" },
  { cls: "n1", bt: "Cero liquidez", bs: "Imposible ahorrar", et: "Puede planear", es: "Y arriesgar un poco" },
  { cls: "n2", bt: "No puede invertir", bs: "Ni negocio ni estudio", et: "Invierte", es: "Mercancía, estudio" },
  { cls: "n3", bt: "Sigue igual", bs: "Nada cambia", et: "Ingreso propio", es: "Crece y se queda" },
];
---
<div class="ec-prog" data-prog aria-hidden="true"></div>

<!-- HERO -->
<section class="ground-ink plus-texture-green ec-sec ec-hero">
  <div class="ec-wrap ec-center">
    <span class="reveal" style="display:inline-block"><LogoBadge size={84} variant="dark" /></span>
    <h1 class="display ec-hero__title reveal">La pobreza no es un hueco.<br />Es una <span class="ec-grn">trampa.</span></h1>
    <p class="ec-lead ec-lead--dark reveal" style="margin-inline:auto">Por qué salir de la pobreza en Colombia no es cuestión de esfuerzo — y cómo una renta básica en efectivo rompe el ciclo. Desliza.</p>
    <div class="ec-scroll reveal"><span class="ec-scroll__t">Desliza</span><span class="ec-scroll__a">↓</span></div>
  </div>
</section>

<!-- 1 · CIFRAS -->
<section class="ground-paper ec-sec">
  <div class="ec-wrap">
    <span class="reveal"><Overline color="var(--coral-500)">El punto de partida</Overline></span>
    <h2 class="display ec-h reveal">¿Qué significa ser <Highlight variant="coral">pobre</Highlight> en cifras?</h2>
    <p class="ec-lead reveal">En Colombia, el DANE traza una línea. Si los ingresos del hogar por persona no alcanzan <strong>$352.480 al mes</strong>, esa familia vive en <CircledWord>pobreza monetaria.</CircledWord> No es una opinión: es no poder cubrir lo básico.</p>

    <div class="meter reveal">
      <div class="meter__line"><span class="meter__line-lab">Línea de pobreza · $352.480</span></div>
      {meters.map((m) => (
        <div class="meter__col">
          <div class="meter__bar" style={`--h:${m.h}px;background:${m.c}`}></div>
          <span class="meter__lab" style={m.below ? "color:var(--coral-500)" : ""}>{m.lab}</span>
        </div>
      ))}
    </div>

    <div class="ec-stats">
      <div class="ec-stat reveal"><div class="ec-stat__big" style="color:var(--coral-500)"><span data-countup data-to="33" data-suffix="%">33%</span></div><p class="ec-stat__lab">de los colombianos vive en pobreza monetaria — 1 de cada 3.</p></div>
      <div class="ec-stat reveal"><div class="ec-stat__big" style="color:var(--coral-500)"><span data-countup data-to="12" data-suffix="%">12%</span></div><p class="ec-stat__lab">en pobreza extrema: ni siquiera alcanza para alimentarse bien.</p></div>
      <div class="ec-stat reveal"><div class="ec-stat__big" style="color:var(--ink-900)"><span data-countup data-to="352480" data-prefix="$">$352.480</span></div><p class="ec-stat__lab">el umbral mensual por persona (DANE). Debajo de ahí empieza la trampa.</p></div>
    </div>
    <p class="ec-src reveal">Fuente · DANE, pobreza monetaria</p>
  </div>
</section>

<!-- 2 · LIQUIDEZ -->
<section class="ground-green ec-sec">
  <div class="ec-wrap">
    <span class="reveal"><Overline tone="dark">El malentendido</Overline></span>
    <h2 class="display ec-h reveal">No es que falte <Highlight variant="dark">esfuerzo.</Highlight> Falta liquidez.</h2>
    <p class="ec-lead reveal" style="color:var(--ink-900);opacity:.85">Una madre que vende mecato en el metrocable trabaja todo el día. El problema no es su voluntad: es que cada peso que entra ya tiene dueño antes de llegar. Sin un colchón, <strong>es imposible invertir en lo que la sacaría adelante</strong> — más mercancía, una herramienta, un curso, la matrícula de un hijo.</p>
    <div class="ec-chips reveal">
      {expenses.map((t) => (
        <span class="ec-chip"><BrandSymbol symbol="equals" size={15} color="var(--green-400)" /> {t}</span>
      ))}
      <span class="ec-chip ec-chip--ghost">Para invertir → $0</span>
    </div>
  </div>
</section>

<!-- 3 · TRAP LOOP -->
<section class="ground-ink ec-sec">
  <div class="ec-wrap ec-center">
    <span class="reveal"><Overline tone="green">El mecanismo</Overline></span>
    <h2 class="display ec-h reveal" style="color:var(--paper-50)">La trampa, en un círculo</h2>
    <p class="ec-lead ec-lead--dark reveal" style="margin-inline:auto">Cada etapa alimenta la siguiente y todo vuelve a empezar. Pulsa el botón para inyectar una <strong class="ec-grn">renta básica</strong> y mira qué pasa con el ciclo.</p>
  </div>
  <div class="ec-wrap">
    <div class="loop reveal" data-loop>
      <div class="loop__diagram">
        <svg viewBox="0 0 360 360" class="loop__svg" aria-hidden="true">
          <defs>
            <marker id="trapArrow" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="5.5" markerHeight="5.5" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" fill="currentColor" /></marker>
            <path id="trapCircle" d="M180 50 A130 130 0 1 1 179.9 50" fill="none" />
          </defs>
          <path d="M180 50 A130 130 0 0 1 310 180" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" marker-end="url(#trapArrow)" />
          <path d="M310 180 A130 130 0 0 1 180 310" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" marker-end="url(#trapArrow)" />
          <path d="M180 310 A130 130 0 0 1 50 180" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" marker-end="url(#trapArrow)" />
          <path d="M50 180 A130 130 0 0 1 180 50" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" marker-end="url(#trapArrow)" />
          <circle r="11" fill="var(--ink-900)"><animateMotion dur="6s" repeatCount="indefinite"><mpath href="#trapCircle" /></animateMotion></circle>
          <circle r="11" fill="none" stroke="currentColor" stroke-width="4"><animateMotion dur="6s" repeatCount="indefinite"><mpath href="#trapCircle" /></animateMotion></circle>
          <text class="loop__center" x="180" y="172" text-anchor="middle" font-family="var(--font-display)" font-weight="900" font-size="30" letter-spacing="-1">EN BUCLE</text>
          <text class="loop__sub" x="180" y="198" text-anchor="middle" font-family="var(--font-mono)" font-weight="700" font-size="12" letter-spacing="2">SIN SALIDA</text>
        </svg>
        {nodes.map((n) => (
          <div class:list={["node", n.cls]} data-node data-bt={n.bt} data-bs={n.bs} data-et={n.et} data-es={n.es}>
            <div class="node__t">{n.bt}</div>
            <div class="node__s">{n.bs}</div>
          </div>
        ))}
      </div>
      <div class="loop__btnwrap">
        <button class="loop__btn" type="button" data-loop-btn><BrandSymbol symbol="plus" size={18} color="var(--ink-900)" /> Añadir renta básica</button>
      </div>
    </div>
  </div>
</section>

<!-- 4 · FEMINIZACIÓN -->
<section class="ground-paper ec-sec">
  <div class="ec-wrap">
    <span class="reveal"><Overline color="var(--coral-500)">Quién carga el peso</Overline></span>
    <h2 class="display ec-h reveal">La pobreza tiene <Highlight variant="coral">cara de mujer.</Highlight></h2>
    <p class="ec-lead reveal">Las madres cabeza de familia sostienen el hogar con menos. En Colombia, las mujeres reciben <strong>12,1% menos ingreso</strong> que los hombres por el mismo trabajo, y la trampa se cierra más fuerte sobre ellas.</p>
    <div class="ec-fem">
      <div class="reveal ec-fem__bars">
        <StatBar label="Ingreso · hombres" value={100} display="100%" fill="var(--ink-900)" />
        <StatBar label="Ingreso · mujeres" value={88} display="−12,1%" fill="var(--coral-400)" />
        <span class="ec-src">Fuente · DANE</span>
      </div>
      <div class="reveal ec-fem__card">
        <div class="ec-fem__people">
          {Array.from({ length: 10 }).map((_, i) => (
            <svg width="25" height="40" viewBox="0 0 40 64" aria-hidden="true"><circle cx="20" cy="13" r="11" fill={i < 6 ? "var(--coral-400)" : "var(--paper-300)"} /><path d="M3 64 C3 40 37 40 37 64 Z" fill={i < 6 ? "var(--coral-400)" : "var(--paper-300)"} /></svg>
          ))}
        </div>
        <p class="ec-fem__txt">Más de la mitad de los hogares en pobreza extrema dependen de una mujer sola.</p>
      </div>
    </div>
  </div>
</section>

<!-- 5 · EFECTIVO -->
<section class="ground-green ec-sec">
  <div class="ec-wrap">
    <div class="ec-cashhead reveal">
      <svg width="70" height="70" viewBox="0 0 100 100" aria-hidden="true" class="ec-coin"><circle cx="50" cy="50" r="46" fill="var(--marigold-400)" stroke="var(--ink-900)" stroke-width="5" /><circle cx="50" cy="50" r="36" fill="none" stroke="var(--ink-900)" stroke-width="3" stroke-dasharray="4 5" opacity="0.55" /><text x="50" y="68" text-anchor="middle" font-family="var(--font-display)" font-weight="900" font-size="46" fill="var(--ink-900)">$</text></svg>
      <div>
        <Overline tone="dark">La pregunta incómoda</Overline>
        <h2 class="display ec-h" style="margin-top:6px">¿Y si simplemente damos <Highlight variant="dark">efectivo?</Highlight></h2>
      </div>
    </div>
    <p class="ec-lead reveal" style="color:var(--ink-900);opacity:.85">Suena ingenuo. Pero cuando se entrega dinero sin condiciones a familias en pobreza, la evidencia mundial dice algo claro: <strong>no se malgasta.</strong> Se transforma.</p>
    <div class="ec-ev">
      {evidence.map((c) => (
        <div class="ec-ev__card reveal">
          <BrandSymbol symbol={c.sym} size={32} color="var(--green-400)" />
          <h3 class="ec-ev__t">{c.t}</h3>
          <p class="ec-ev__d">{c.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- 6 · CERTEZA -->
<section class="ground-paper ec-sec">
  <div class="ec-wrap">
    <span class="reveal"><Overline color="var(--green-700)">La salida</Overline></span>
    <h2 class="display ec-h reveal">Lo que cambia es la <Highlight>certeza.</Highlight></h2>
    <p class="ec-lead reveal">Una renta básica <strong>mensual y predecible</strong> no es un regalo: es el colchón que permite dejar de apagar incendios y empezar a planear. Ahí el círculo deja de girar y se convierte en una espiral hacia arriba.</p>
    <div class="ec-steps reveal">
      {steps.map((s, i) => (
        <div class:list={["ec-step", { "ec-step--last": i === 3 }]}>
          <span class="ec-step__n">{s.n}</span>
          <h3 class="ec-step__t">{s.t}</h3>
          <p class="ec-step__d">{s.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- 7 · MODELO 1+ + CTA -->
<section class="ground-ink plus-texture-green ec-sec">
  <div class="ec-wrap ec-center">
    <span class="reveal"><Overline tone="green">Aquí entras tú</Overline></span>
    <h2 class="display ec-h reveal" style="color:var(--paper-50);margin-inline:auto">Una familia no puede sola.<br /><Highlight variant="green">Muchos amigos, sí.</Highlight></h2>
    <p class="ec-lead ec-lead--dark reveal" style="margin-inline:auto">El Club del 1+ junta el aporte recurrente de cientos de amigos comprometidos en un fondo, y lo convierte en renta básica para madres cabeza de familia. Así de simple.</p>

    <div class="ec-eq reveal">
      <div class="ec-eq__term"><span class="ec-eq__circle"><BrandSymbol symbol="ring" size={36} color="var(--green-400)" /></span><span class="ec-eq__lab">Tú</span></div>
      <BrandSymbol symbol="plus" size={36} color="var(--green-400)" />
      <div class="ec-eq__term"><span class="ec-eq__circle"><BrandSymbol symbol="ring" size={36} color="var(--green-400)" /></span><span class="ec-eq__lab">Cientos de amigos</span></div>
      <BrandSymbol symbol="equals" size={36} color="var(--green-400)" />
      <div class="ec-eq__term"><span class="ec-eq__circle ec-eq__circle--hl"><BrandSymbol symbol="rise" size={36} color="var(--ink-900)" /></span><span class="ec-eq__lab ec-eq__lab--hl">Riqueza que sale de la pobreza</span></div>
    </div>

    <div class="ec-cta reveal">
      <Button href={donar} variant="primary" size="lg">Súmate al Club</Button>
      <Button href={benef} variant="outline-on-dark" size="lg">Conoce a las beneficiarias</Button>
    </div>
    <p class="ec-tagline reveal">La mejor forma de eliminar la pobreza es creando riqueza.</p>
    <p class="ec-handle reveal">El Club del 1+ · @clubdel1_</p>
  </div>
</section>

<div class="ec-disclaimer">
  <p>Cifras de pobreza monetaria y brecha de ingresos: DANE (umbral per cápita citado por El Club del 1+). El comportamiento de las transferencias monetarias no condicionadas resume hallazgos generales de la literatura sobre el tema; no representa un estudio único. Pieza ilustrativa de divulgación.</p>
</div>

<script>
  function setupExplainer() {
    // progreso de scroll
    const prog = document.querySelector("[data-prog]") as HTMLElement | null;
    if (prog) {
      const onScroll = () => {
        const h = document.documentElement;
        const max = h.scrollHeight - h.clientHeight;
        prog.style.width = (max > 0 ? (h.scrollTop / max) * 100 : 0) + "%";
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    }
    // count up
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        const el = e.target as HTMLElement;
        io.unobserve(el);
        const to = parseFloat(el.dataset.to || "0");
        const prefix = el.dataset.prefix || "", suffix = el.dataset.suffix || "";
        let start = 0;
        const tick = (t: number) => {
          if (!start) start = t;
          const p = Math.min(1, (t - start) / 1400);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = prefix + Math.round(to * eased).toLocaleString("es-CO") + suffix;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }
    }, { threshold: 0.5 });
    document.querySelectorAll("[data-countup]").forEach((el) => io.observe(el));

    // trap loop toggle
    document.querySelectorAll("[data-loop]").forEach((node) => {
      const loop = node as HTMLElement;
      const btn = loop.querySelector("[data-loop-btn]");
      if (!btn || loop.dataset.bound) return;
      loop.dataset.bound = "1";
      const origBtn = btn.innerHTML;
      btn.addEventListener("click", () => {
        const broken = loop.classList.toggle("is-broken");
        loop.querySelectorAll("[data-node]").forEach((nd) => {
          const n = nd as HTMLElement;
          (n.querySelector(".node__t") as HTMLElement).textContent = broken ? n.dataset.et! : n.dataset.bt!;
          (n.querySelector(".node__s") as HTMLElement).textContent = broken ? n.dataset.es! : n.dataset.bs!;
        });
        const c = loop.querySelector(".loop__center"); if (c) c.textContent = broken ? "EN ESPIRAL" : "EN BUCLE";
        const s = loop.querySelector(".loop__sub"); if (s) s.textContent = broken ? "HACIA ARRIBA" : "SIN SALIDA";
        btn.innerHTML = broken ? "↺ Quitar la renta básica" : origBtn;
      });
    });
  }
  document.addEventListener("astro:page-load", setupExplainer);
</script>

<style>
  .ec-prog { position: fixed; top: 0; left: 0; height: 4px; width: 0; background: var(--green-400); z-index: 60; transition: width 80ms linear; }
  .ec-sec { padding-block: clamp(64px, 9vw, 120px); }
  .ec-hero { padding-block: clamp(72px, 11vw, 140px); }
  .ec-wrap { max-width: 920px; margin-inline: auto; padding-inline: clamp(20px, 5vw, 24px); }
  .ec-center { text-align: center; }
  .ec-grn { color: var(--green-400); }
  .ec-hero__title { font-size: clamp(44px, 8vw, 96px); line-height: 0.95; letter-spacing: -0.04em; color: var(--paper-50); margin: 24px auto 0; max-width: 16ch; }
  .ec-h { font-size: clamp(34px, 5.2vw, 58px); line-height: 1.08; letter-spacing: -0.025em; color: var(--ink-900); margin-top: 16px; padding-bottom: 0.4em; text-wrap: balance; }
  .ec-lead { font-family: var(--font-body); font-weight: 500; font-size: clamp(17px, 2vw, 21px); line-height: 1.55; color: var(--text-body); margin-top: 12px; max-width: 54ch; }
  .ec-lead--dark { color: var(--text-on-dark); }
  .ec-lead strong { font-weight: 800; }
  .ec-src { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-faint); margin-top: 18px; }
  .ec-scroll { display: inline-flex; flex-direction: column; align-items: center; gap: 8px; color: var(--green-400); margin-top: 40px; }
  .ec-scroll__t { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; }
  .ec-scroll__a { font-size: 24px; animation: ecBounce 1.6s infinite; }
  @keyframes ecBounce { 0%,100% { transform: translateY(0); } 50% { transform: translateY(7px); } }

  /* threshold meter */
  .meter { position: relative; height: 230px; display: flex; align-items: flex-end; gap: 22px; padding: 0 8px; margin-top: 48px; }
  .meter__line { position: absolute; left: 0; right: 0; top: 56px; border-top: 3px dashed var(--ink-900); z-index: 3; }
  .meter__line-lab { position: absolute; right: 0; top: -26px; font-family: var(--font-mono); font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-900); }
  .meter__col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 10px; justify-content: flex-end; }
  .meter__bar { width: 100%; max-width: 120px; height: var(--h); border: 2px solid var(--ink-900); border-bottom: none; border-radius: 10px 10px 0 0; }
  .meter__lab { font-family: var(--font-body); font-weight: 700; font-size: 13.5px; color: var(--text-strong); text-align: center; }

  .ec-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 64px; }
  .ec-stat { border-top: 3px solid var(--ink-900); padding-top: 16px; }
  .ec-stat__big { font-family: var(--font-display); font-weight: 900; font-size: clamp(34px, 4.5vw, 48px); letter-spacing: -0.02em; line-height: 1; }
  .ec-stat__lab { font-family: var(--font-body); font-weight: 500; font-size: 15px; line-height: 1.45; color: var(--text-muted); margin-top: 12px; }

  .ec-chips { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 44px; }
  .ec-chip { display: inline-flex; align-items: center; gap: 8px; background: var(--ink-900); color: var(--green-400); font-family: var(--font-display); font-weight: 800; font-size: 15px; padding: 10px 16px; border-radius: var(--radius-pill); }
  .ec-chip--ghost { background: transparent; color: var(--ink-900); border: 2px dashed var(--ink-900); }

  /* trap loop */
  .loop { width: 100%; max-width: 560px; margin: 0 auto; color: var(--coral-400); }
  .loop.is-broken { color: var(--green-400); }
  .loop__diagram { position: relative; width: 100%; aspect-ratio: 1 / 1; }
  .loop__svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .loop__center { fill: var(--coral-500); }
  .loop.is-broken .loop__center { fill: var(--green-700); }
  .loop__sub { fill: var(--ink-900); opacity: 0.55; }
  .loop.is-broken .loop__sub { fill: var(--paper-50); opacity: 0.7; }
  .node { position: absolute; width: 150px; background: var(--paper-0); border: 2px solid var(--ink-900); border-radius: 12px; padding: 9px 12px; box-shadow: var(--shadow-md); }
  .node__t { font-family: var(--font-display); font-weight: 800; font-size: 14px; color: var(--ink-900); line-height: 1.12; white-space: nowrap; }
  .node__s { font-family: var(--font-body); font-weight: 500; font-size: 11.5px; color: var(--text-muted); margin-top: 3px; line-height: 1.25; }
  .node.n0 { left: 50%; top: 16%; transform: translate(-50%, -78%); }
  .node.n1 { left: 88%; top: 52%; transform: translate(-26%, -50%); }
  .node.n2 { left: 50%; top: 88%; transform: translate(-50%, -22%); }
  .node.n3 { left: 12%; top: 52%; transform: translate(-74%, -50%); }
  .loop__btnwrap { display: flex; justify-content: center; margin-top: 18px; }
  .loop__btn { display: inline-flex; align-items: center; gap: 10px; font-family: var(--font-display); font-weight: 800; font-size: 16px; padding: 13px 24px; border-radius: var(--radius-pill); cursor: pointer; background: var(--green-400); color: var(--ink-900); border: 2px solid var(--green-400); transition: filter var(--dur-fast) var(--ease-out); }
