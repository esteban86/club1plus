---
import Overline from "../brand/Overline.astro";
import Button from "../brand/Button.astro";
import { getLangFromUrl, getRoute } from "../../i18n/utils";
import { PUBLIC_STATS } from "../../lib/demo/data";
const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const isEn = lang === "en";
const numLocale = isEn ? "en-US" : "es-CO";

const c = {
  over: isEn ? "The community, live" : "La comunidad, en vivo",
  heading: isEn ? "We're already moving the needle — together." : "Ya estamos moviendo la balanza — juntos.",
  members: isEn ? "members" : "socios",
  mothers: isEn ? "mothers with income" : "madres con renta",
  transferred: isEn ? "transferred to mothers" : "transferido a las madres",
  forming: isEn ? "more mothers forming their circle" : "madres más completando su círculo",
  cta: isEn ? "See the community grow" : "Mira crecer la comunidad",
  note: isEn ? "Demo figures · sample data" : "Cifras de la demo · datos de prueba",
};

// Sparkline (crecimiento de socios)
const g = PUBLIC_STATS.growth;
const maxG = Math.max(...g);
const W = 240, H = 56;
const pts = g.map((v, i) => `${((i / (g.length - 1)) * W).toFixed(1)},${(H - (v / maxG) * (H - 6) - 3).toFixed(1)}`).join(" ");
const area = `0,${H} ${pts} ${W},${H}`;
---
<section class="ground-ink section livec plus-texture-green">
  <div class="container">
    <Overline tone="green">{c.over}</Overline>
    <h2 class="display livec__title">{c.heading}</h2>
    <div class="livec__grid">
      <div class="livec__stat reveal">
        <div class="livec__n" data-count data-to={PUBLIC_STATS.members} data-locale={numLocale}>0</div>
        <div class="livec__l">{c.members}</div>
      </div>
      <div class="livec__stat reveal">
        <div class="livec__n" data-count data-to={PUBLIC_STATS.mothersActive} data-locale={numLocale}>0</div>
        <div class="livec__l">{c.mothers}</div>
      </div>
      <div class="livec__stat reveal">
        <div class="livec__n" data-count data-to={PUBLIC_STATS.transferredCop} data-locale={numLocale} data-prefix="$" data-compact="cop">$0</div>
        <div class="livec__l">{c.transferred}</div>
      </div>
    </div>
    <div class="livec__foot">
      <div class="livec__spark">
        <svg viewBox={`0 0 ${W} ${H}`} width={W} height={H} role="img" aria-label="growth">
          <polygon points={area} fill="rgba(43,224,111,0.16)" />
          <polyline points={pts} fill="none" stroke="#2BE06F" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" />
        </svg>
        <span class="livec__sparkl">+{PUBLIC_STATS.mothersInFormation} {c.forming}</span>
      </div>
      <Button href={base + getRoute("comunidad", lang)} variant="primary" size="md">{c.cta} →</Button>
    </div>
    <p class="livec__note">{c.note}</p>
  </div>
</section>
<style>
  .livec__title { font-size: clamp(28px, 4.5vw, 44px); color: var(--paper-50); margin-top: 14px; max-width: 20ch; line-height: 1.1; }
  .livec__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px; }
  @media (max-width: 720px) { .livec__grid { grid-template-columns: 1fr; gap: 28px; } }
  .livec__stat { border-left: 3px solid var(--green-400); padding-left: 18px; }
  .livec__n { font-family: var(--font-display); font-weight: 900; letter-spacing: -0.03em; font-size: clamp(40px, 6vw, 64px); color: var(--green-400); line-height: 1; }
  .livec__l { font-family: var(--font-body); font-weight: 600; font-size: 15px; color: var(--text-on-dark); margin-top: 8px; }
  .livec__foot { display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; margin-top: 40px; }
  .livec__spark { display: flex; align-items: center; gap: 14px; }
  .livec__sparkl { font-family: var(--font-mono); font-size: 12.5px; color: var(--text-on-dark-muted); }
  .livec__note { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-400); margin-top: 22px; }
</style>
<script>
  import { initCountUp } from "../../lib/demo/countup";
  document.addEventListener("astro:page-load", initCountUp);
</script>
