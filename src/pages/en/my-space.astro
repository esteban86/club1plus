---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DemoBadge from "../../components/brand/DemoBadge.astro";
import { getLangFromUrl } from "../../i18n/utils";
import "../../styles/portal.css";
const lang = getLangFromUrl(Astro.url);
---
<BaseLayout routeKey="miEspacio" title="My space" description="Your El Club del 1+ member space." noindex>
  <section class="app-shell">
    <div class="app-wrap">
      <div style="margin-bottom:14px"><DemoBadge /></div>
      <div id="portal" data-lang={lang}>
        <noscript><p class="pf-muted">This demo needs JavaScript enabled.</p></noscript>
      </div>
    </div>
  </section>
</BaseLayout>
<script>
  import { initDashboard } from "../../lib/demo/portal-ui";
  document.addEventListener("astro:page-load", initDashboard);
</script>
